# ─────────────────────────────────────────────────────────────
# Janman Survey — environment template
# Copy to `.env.local` and fill in values. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── App / Auth ───────────────────────────────────────────────
AUTH_SECRET=                       # openssl rand -base64 48
SESSION_MAX_AGE=604800             # session lifetime in seconds (7 days)

# ── MongoDB (source of truth) ────────────────────────────────
MONGODB_URI=
MONGODB_DB=janman_survey

# ── Cloudflare R2 (image storage) ────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=                       # https://<account>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=                # https://media.example (no trailing slash)

# ── Frappe (funder subset sync) ──────────────────────────────
FRAPPE_BASE_URL=https://patna.dignifiedlife.in
FRAPPE_API_KEY=
FRAPPE_API_SECRET=
FRAPPE_USR=
FRAPPE_PWD=
FRAPPE_HOUSEHOLD_DOCTYPE=Household Detail

# ── First-run seed (initial Director) ────────────────────────
SEED_SECRET=
SEED_DIRECTOR_NAME=Shourya Roy
SEED_DIRECTOR_EMAIL=
SEED_DIRECTOR_PASSWORD=
